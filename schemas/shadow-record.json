{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SRE Shadow-Mode Telemetry Record",
  "type": "object",
  "required": [
    "incident_id",
    "skill",
    "scenario_id",
    "recorded_at",
    "agent_proposal",
    "human_decision",
    "match_classification",
    "outcome"
  ],
  "additionalProperties": false,
  "properties": {
    "incident_id": {"type": "string", "minLength": 1},
    "skill": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "recorded_at": {"type": "string", "minLength": 1},
    "agent_proposal": {
      "type": "object",
      "required": [
        "action_template_id",
        "params_hash",
        "brief_confidence",
        "domain_supervisor_endorsement",
        "generalist_supervisor_endorsement",
        "evidence_bundle_hash",
        "brief_redacted"
      ],
      "additionalProperties": false,
      "properties": {
        "action_template_id": {"type": "string", "minLength": 1},
        "params_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "brief_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "domain_supervisor_endorsement": {"type": "string", "enum": ["endorse", "reject", "timeout", "error"]},
        "generalist_supervisor_endorsement": {"type": "string", "enum": ["endorse", "reject", "timeout", "error"]},
        "evidence_bundle_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "brief_redacted": {"type": "string"}
      }
    },
    "human_decision": {
      "type": "object",
      "required": [
        "approved_action_template_id",
        "rejected_reason",
        "operator_role",
        "decided_at"
      ],
      "additionalProperties": false,
      "properties": {
        "approved_action_template_id": {"type": ["string", "null"]},
        "rejected_reason": {"type": ["string", "null"]},
        "operator_role": {"type": "string", "minLength": 1},
        "decided_at": {"type": "string", "minLength": 1}
      }
    },
    "match_classification": {
      "type": "string",
      "enum": ["exact", "equivalent", "divergent", "human_only", "agent_only"]
    },
    "outcome": {
      "type": "object",
      "required": [
        "incident_resolved",
        "resolution_latency_seconds",
        "follow_on_incident_id",
        "attribution_source"
      ],
      "additionalProperties": false,
      "properties": {
        "incident_resolved": {"enum": [true, false, "unknown"]},
        "resolution_latency_seconds": {"type": ["integer", "null"]},
        "follow_on_incident_id": {"type": ["string", "null"]},
        "attribution_source": {"type": "string", "enum": ["operator_confirmed", "inferred", "unconfirmed"]}
      }
    }
  }
}
